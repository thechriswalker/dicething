{
	"name": "dicething-v3",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 55580 --host",
		"prebuild": "./scripts/git_info_to_dotenv.sh",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest --project client --project server",
		"test": "npm run test:unit -- --run",
		"test:slow": "vitest --project slow --run",
		"generate:fonts": "vite-node --options.transformMode.ssr='/.*/' src/lib/fonts/build_builtins.ts",
		"vite-node": "vite-node --options.transformMode.ssr='/.*/'"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.1",
		"@inlang/paraglide-js": "^2.5.0",
		"@lucide/svelte": "1.23.0",
		"@skeletonlabs/skeleton": "^4.6.1",
		"@skeletonlabs/skeleton-svelte": "^4.6.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tailwindcss/vite": "^4.1.17",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.9",
		"@types/node": "^22.19.1",
		"@types/opentype.js": "^1.3.8",
		"@types/three": "^0.176.0",
		"@types/xmldom": "^0.1.34",
		"bits-ui": "^1.8.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"jsdom": "^26.1.0",
		"lucide-static": "^0.508.0",
		"opentype.js": "^1.3.4",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.45.2",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.17",
		"three": "^0.176.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite": "^6.4.1",
		"vite-node": "^3.2.4",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"fflate": "^0.8.3",
		"libtess": "^1.2.2",
		"manifold-3d": "^3.5.1",
		"xmldom": "^0.6.0"
	}
}
